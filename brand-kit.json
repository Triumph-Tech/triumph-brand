    "interface": {
      "description": "A seven-step neutral scale from least contrast (softest) to most contrast (strongest). Scale inverts symmetrically in dark mode — softest becomes the darkest background, strongest becomes the lightest foreground.",
      "softest":   { "light": "#FDFDFD", "dark": "#0D1117" },
      "softer":    { "light": "#F8F8FC", "dark": "#0A0A0A" },
      "soft":      { "light": "#D9D9E3", "dark": "#3D444D" },
      "medium":    { "light": "#8B8BA7", "dark": "#8B8BA7" },
      "strong":    { "light": "#3D444D", "dark": "#D9D9E3" },
      "stronger":  { "light": "#0D1117", "dark": "#F8F8FC" },
      "strongest": { "light": "#0A0A0A", "dark": "#FDFDFD" }
    },
    "semantic": {
      "mode_behavior": "forecolor is the text or icon color for semantic states; background is the tinted surface behind it. Both provide light and dark mode values.",
      "success": {
        "forecolor":  { "light": "#01A11E", "dark": "#80D08F" },
        "background": { "light": "#EBF7ED", "dark": "#0B2E18" }
