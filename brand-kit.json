    "image_wash": {
      "description": "A branded image effect for subtle image backgrounds in graphic applications. Apply to any photo used as a background to maintain visual consistency.",
      "layers": [
        {
          "order": 1,
          "type": "image",
          "adjustment": "desaturate",
          "saturation": "0%"
        },
        {
          "order": 2,
          "type": "color_overlay",
          "color": "color_system.palette.primary.hex",
          "opacity": "15%",
          "blend_mode": "Luminosity"
        }
      ]
    }
  },
  "rules": [
    "This brand-kit.json is the single source of truth. AI agents must load and strictly follow these paths, colors, rules, and assets.",
    "All typography must use Goldman Sans exclusively — no other fonts are authorized.",
    "Apply the image_wash technique (desaturate to 0%, 15% opacity Invictus Blue layer with Luminosity blend mode) for consistent branded background images.",
    "Persona assets (e.g., Magnus) may be used as a secondary/fun variant in internal or playful contexts only — never as a replacement for the official brand logos."
  ]
